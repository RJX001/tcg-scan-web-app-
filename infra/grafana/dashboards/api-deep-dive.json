{
  "uid": "tcgscan-api-deep-dive",
  "title": "TCG Scan \u2014 API Deep Dive",
  "tags": [
    "tcgscan",
    "api",
    "deep-dive",
    "terraform"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "description": "Investigation dashboard: per-route/host HTTP detail, outbound dependency latency, retry/cache degradation events, and scan-stage drill-down.",
  "links": [
    {
      "title": "API Overview",
      "type": "link",
      "url": "/d/tcgscan-api-overview",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Scan Funnel",
      "type": "link",
      "url": "/d/tcgscan-scan-funnel",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Snapshot",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Req/s (5m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "p95 latency (5m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\", http_status_code=~\"5..\"}[15m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[15m])), 1e-9)",
          "refId": "A"
        }
      ],
      "title": "5xx ratio (15m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
