{
  "uid": "tcgscan-scan-funnel",
  "title": "TCG Scan \u2014 Scan Funnel",
  "tags": [
    "tcgscan",
    "scan",
    "terraform"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Scan SLIs",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.99
              },
              {
                "color": "green",
                "value": 0.995
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(tcgscan_scan_count_total{job=\"tcgscan/tcgscan-api\", tcgscan_scan_outcome=~\"ok|cache_hit\"}[1h])) / sum(rate(tcgscan_scan_count_total{job=\"tcgscan/tcgscan-api\"}[1h]))",
          "refId": "A"
        }
      ],
      "title": "Scan success rate (1h)",
      "type": "stat",
      "description": "Draft SLO: \u226599% ok+cache_hit (sre.md)."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2.5
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(tcgscan_scan_duration_seconds_bucket{job=\"tcgscan/tcgscan-api\"}[1h])))",
          "refId": "A"
        }
      ],
      "title": "Scan p95 latency (1h)",
      "type": "stat",
      "description": "Draft SLO: p95 < 2.5s (Phase-1 KPI)."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(tcgscan_ml_requests_total{job=\"tcgscan/tcgscan-api\", tcgscan_ml_mode=\"fallback\"}[1h])) / clamp_min(sum(rate(tcgscan_ml_requests_total{job=\"tcgscan/tcgscan-api\"}[1h])), 1e-9)",
          "refId": "A"
        }
      ],
      "title": "ML fallback ratio (1h)",
      "type": "stat",
      "description": "Draft SLO: fallback < 1% when Modal URLs are configured."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\", http_status_code=~\"5..\"}[1h])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[1h])), 1e-9)",
          "refId": "A"
        }
      ],
      "title": "API 5xx ratio (1h)",
      "type": "stat",
      "description": "Draft SLO: availability \u2265 99.5%."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 10,
      "targets": [
        {
          "expr": "sum by (tcgscan_scan_outcome) (rate(tcgscan_scan_count_total{job=\"tcgscan/tcgscan-api\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{tcgscan_scan_outcome}}"
        }
      ],
      "title": "Scan rate by outcome",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 11,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(tcgscan_scan_duration_seconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(tcgscan_scan_duration_seconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ],
      "title": "Scan duration p50 / p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tcgscan_scan_stage) (rate(tcgscan_scan_stage_duration_seconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "{{tcgscan_scan_stage}}"
        }
      ],
      "title": "Stage p95 duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 13,
      "targets": [
        {
          "expr": "sum by (tcgscan_ml_endpoint, tcgscan_ml_mode) (rate(tcgscan_ml_requests_total{job=\"tcgscan/tcgscan-api\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{tcgscan_ml_endpoint}} / {{tcgscan_ml_mode}}"
        }
      ],
      "title": "ML requests by endpoint / mode",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 20,
      "title": "Error signals",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-logs"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 21,
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service_name=\"tcgscan/tcgscan-api\", level=~\"ERROR|WARNING|CRITICAL\"} | json event=\"body.event\" [$__auto]))",
          "refId": "A",
          "legendFormat": "{{event}}"
        }
      ],
      "title": "ERROR / WARNING events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-logs"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 22,
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service_name=\"tcgscan/tcgscan-api\", level=\"ERROR\"} | json",
          "refId": "A"
        }
      ],
      "title": "Recent ERROR logs",
      "type": "logs"
    }
  ],
  "links": [
    {
      "title": "API Deep Dive",
      "type": "link",
      "url": "/d/tcgscan-api-deep-dive",
      "icon": "dashboard",
      "targetBlank": false
    }
  ]
}
