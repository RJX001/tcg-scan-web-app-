      },
      "id": 32,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "B",
