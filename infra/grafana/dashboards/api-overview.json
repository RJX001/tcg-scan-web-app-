    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 10
      },
      "id": 33,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_client_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\", http_status_code=~\"4..|5..\"}[30m])) / sum(rate(http_client_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "Outbound error ratio (30m)",
      "type": "stat",
      "description": "Share of outbound httpx calls returning 4xx/5xx. Covers Modal ML endpoints, eBay, and catalog sources."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
