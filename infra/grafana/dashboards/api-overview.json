{
  "uid": "tcgscan-api-overview",
  "title": "TCG Scan \u2014 API Overview",
  "tags": [
    "tcgscan",
    "api",
    "terraform"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "HTTP server (FastAPI auto-instrumentation)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{http_status_code}}"
        }
      ],
      "title": "Request rate by status code",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "title": "HTTP latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\", http_status_code=~\"5..\"}[30m])) / sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "5xx ratio (30m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "Request rate (30m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "id": 6,
      "targets": [
        {
          "expr": "topk(8, sum by (http_target) (rate(http_server_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "{{http_target}}"
        }
      ],
      "title": "Top request paths",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 30,
