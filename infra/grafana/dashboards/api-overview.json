      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-logs"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "id": 35,
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service_name=\"tcgscan/tcgscan-api\"} | json event=\"body.event\" | event=~\"http.retry.*\" [$__auto]))",
          "refId": "A",
          "legendFormat": "{{event}}"
        }
      ],
      "title": "Outbound retry + exhaustion log events",
      "type": "timeseries",
      "description": "http.retry (WARNING, per attempt) and http.retries_exhausted (ERROR) from the API retry client."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 10,
      "title": "Scan pipeline + ML (populates on first scan after deploy)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
