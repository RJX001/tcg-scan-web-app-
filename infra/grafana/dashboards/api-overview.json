      "id": 31,
      "targets": [
        {
          "expr": "sum by (http_method, http_status_code) (rate(http_client_duration_milliseconds_count{job=\"tcgscan/tcgscan-api\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{http_method}} {{http_status_code}}"
        }
