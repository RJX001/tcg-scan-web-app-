{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://clerk.cardchart.co.uk https://*.clerk.accounts.dev https://accounts.cardchart.co.uk;"
        }
      ]
    }
  ]
}
