# Database
DATABASE_URL=postgresql+asyncpg://tcgscan:tcgscan@localhost:5433/tcgscan

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_BUCKET=tcgscan-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=

# Clerk
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Anthropic (agents only)
ANTHROPIC_API_KEY=

# Modal (CI / deploy + ML endpoint URLs)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_DETECT_URL=
MODAL_EMBED_URL=
MODAL_OCR_URL=
MODAL_GRADE_URL=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# eBay
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=
EBAY_INSIGHTS_TOKEN=

# Catalog APIs
POKEMONTCG_API_KEY=

# TCG / pricing APIs
TCG_API_KEY=

# Cardmarket scrapers
APIFY_TOKEN=
APIFY_CARDMARKET_DATASET_ID=cardmarket-trend

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tcg-scan-dev

# Sentry (one per app)
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_WORKER=
SENTRY_DSN_ML=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev mode — bypass Clerk when keys are absent; use header X-Dev-User-Id
DEV_AUTH_ENABLED=true
FREE_SCANS_PER_DAY=10
FREE_PORTFOLIO_LIMIT=25

# Stripe Pro ($9.99/mo) — create product in Stripe dashboard
STRIPE_PRO_PRICE_ID=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
