# Runtime
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://tcgscan:tcgscan@localhost:5433/tcgscan

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_BUCKET=tcgscan-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=

# Clerk (deprecated — keep until Supabase verified in production)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portfolio
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portfolio

# Supabase Auth (auth only — app DB stays on Railway Postgres)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Anthropic (agents only)
ANTHROPIC_API_KEY=

# Modal (CI / deploy + ML endpoint URLs)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_DETECT_URL=
MODAL_EMBED_URL=
MODAL_OCR_URL=
MODAL_GRADE_URL=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# eBay (UK marketplace default — set EBAY_US for US comps)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=
EBAY_INSIGHTS_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_GB

# Catalog APIs
POKEMONTCG_API_KEY=

# TCG / pricing APIs
TCG_API_KEY=

# Cardmarket scrapers
APIFY_TOKEN=
APIFY_CARDMARKET_DATASET_ID=cardmarket-trend

# PSA Population Report API (free tier ~100 calls/day)
PSA_API_TOKEN=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tcg-scan-dev

# Sentry (one per app)
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_WORKER=
SENTRY_DSN_ML=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Set true only after Modal embed endpoints are deployed
NEXT_PUBLIC_SCAN_ENABLED=true

# Dev mode — bypass auth when no Supabase/Clerk keys; use header X-Dev-User-Id
OWNER_EMAIL=
DEV_AUTH_ENABLED=true
FREE_SCANS_PER_DAY=10
FREE_PORTFOLIO_LIMIT=25

# Stripe Pro ($9.99/mo) — create product in Stripe dashboard
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=https://tcgchart.co.uk/account?checkout=success
STRIPE_CANCEL_URL=https://tcgchart.co.uk/account?checkout=cancel
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# Production API (Railway)
# ENVIRONMENT=production
# CORS_ORIGINS=https://tcgchart.co.uk,https://www.tcgchart.co.uk
# CLERK_AUTHORIZED_PARTIES=https://tcgchart.co.uk,https://www.tcgchart.co.uk
# NEXT_PUBLIC_SITE_URL=https://tcgchart.co.uk
# NEXT_PUBLIC_SCAN_ENABLED=false
